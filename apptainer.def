Bootstrap: docker
From: rocker/rstudio

%post
    # Install system dependencies (geospatial libs for sf, etc.)
    apt-get update && apt-get install -y \
        curl \
        git \
        libgdal-dev \
        libproj-dev \
        libgeos-dev \
        libudunits2-dev \
        && rm -rf /var/lib/apt/lists/*